const ul = document.querySelector("#ul");
const form = document.querySelector('#form_cities');
const cityInput = document.querySelector("input[name='city']");

let elements = loadFromLocalStorage() || ["Rio Tercero", "Cordoba Capital", "Corralito"];
form.addEventListener("submit" , (e) => {
  createElementForm(e,cityInput);
});

function renderList(){
  ul.innerHtml = '';
  const fragment = document.createDocumentFragment();
  elements.forEach((city) => {
   newLiElement(fragment,city);
  });
  ul.appendChild(fragment);
}

renderList();

ul.addEventListener('click', (e) => {
  const button = e.target;
  const li = button.closest('li');

  if(!li) return;

  if(e.target.classList.contains(`remove_button`)) {
    li.remove();
  }
  else if(e.target.classList.contains('edit_button')) {
   const span = li.querySelector('.li-content');
    const text = prompt('editando', span.textContent);
    if(text) span.textContent = text;
  }
});

function saveToLocalStorage() {
  const cities = Array.from(ul.querySelectorAll('.li-content')).map(span => span.textContent);
  localStorage.setItem('cities',JSON.stringfly(cities));
}
function loadFromLocalStorage() {
  cosnt storedItems = localStorage.getItems('cities');
  if(storedItems){
    return JSON.parse(storedItems);
  } else return null;
}

function newLiElement(fragment, cityName) {
  const li = document.createElement("li");
  li.classList.add("list");

  const span = document.createElement('span');
  span.textContent = cityName;
  span.classList.add('li-content');
  
  const remove_button = document.createElement('button');
  remove_button.textContent = 'eliminar';
  remove_button.classList.add('remove_button');

  const edit_button = document.createElement('button');
  edit_button.textContent = 'editar';
  edit_button.classList.add('edit_button');

  li.appendChild(span);
  li.appendChild(edit_button);
  li.appendChild(remove_button);
  fragment.appendChild(li);
}
function createElementForm(e,cityInput) {
    e.preventDefault();
    const newElement = document.createDocumentFragment();
    newLiElement(newElement,cityInput.value);
    ul.appendChild(newElement);
    cityInput.value = '';
    saveToLocalStorage();
  }

